# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Build / packaging
build/
dist/
*.egg-info/

# Notebook / editor noise
.ipynb_checkpoints/
.idea/
.vscode/

# Local generated outputs
outputs/
runs/
contour_runs/
*.svg
*.png

# Keep example source images unless explicitly moved
!examples/
!examples/*.jpeg
!examples/*.jpg
!examples/*.png

# Ralph loop runtime artifacts (per-tick dumps, pidfiles, generated outputs)
loop/*.pid
loop/log/
loop/output/*
loop/holdout/output_*

# ...but force-track the judge calibration anchor: it's a runtime dependency
# (loop/judge.py loads it as ANCHOR_95), not a regenerable output. The parent
# dir is matched by a glob (not a dir-ignore) so this negation can take effect.
!loop/output/iter_014.png

# Sweep experiments are throwaway exploration — keep them OUT of git (regenerable
# locally; the substantive outcome is baked into engine defaults + render_tick).
loop/sweep.py
loop/sweep_results.jsonl
loop/WAVE_SWEEP.md
loop/sweep_best.png
loop/sweep_best.svg

# Force-track the marching-waves sample renders as durable visual references
# (the *.png/*.svg rules above would otherwise ignore them). Regenerable via
# `python loop/render.py N --method march` with the noted MARCH_* knobs.
!loop/march_sample_expressive.png
!loop/march_sample_expressive.svg
!loop/march_sample_balanced.png
!loop/march_sample_balanced.svg
!loop/march_sample_diamond.png
!loop/march_sample_diamond.svg
