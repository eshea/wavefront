# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Build / packaging
build/
dist/
*.egg-info/

# Notebook / editor noise
.ipynb_checkpoints/
.idea/
.vscode/

# Local generated outputs
outputs/
runs/
contour_runs/
*.svg
*.png

# Keep example source images unless explicitly moved
!examples/
!examples/*.jpeg
!examples/*.jpg
!examples/*.png

# Ralph loop runtime artifacts (per-tick dumps, pidfiles, generated outputs)
loop/*.pid
loop/log/
loop/output/*
loop/holdout/output_*

# Generated per-tick situational artifacts (regenerated by score_tick.sh; never
# commit — they reflect the live state, not a versioned fact). The montage/best
# images (loop/output/_latest_compare.png, _best.png, _best.json) are already
# covered by loop/output/* above.
loop/STATUS.md
loop/EXPERIMENT_DIGEST.md
loop/.guard_feedback

# ...but force-track a couple of files: iter_014.png is the input for
# loop/tests/score_smoke.sh, and current-woman.* is the tracked "very good"
# canonical render (method=march) — documented evidence in EXPERIMENT_LOG.md.
# The parent dir is matched by a glob (not a dir-ignore) so these negations take effect.
!loop/output/iter_014.png
!loop/output/current-woman.png
!loop/output/current-woman.svg

# Sweep experiments are throwaway exploration — keep them OUT of git (regenerable
# locally; the substantive outcome is baked into engine defaults + render_tick).
loop/sweep.py
loop/sweep_results.jsonl
# optimizer leaderboard — regenerable per-run artifact (loop/optimize.py is tracked).
loop/optimize_log.jsonl
loop/WAVE_SWEEP.md
loop/sweep_best.png
loop/sweep_best.svg

# Force-track the marching-waves sample renders as durable visual references
# (the *.png/*.svg rules above would otherwise ignore them). Regenerable via
# `python loop/render.py N --method march` with the noted MARCH_* knobs.
!loop/march_sample_expressive.png
!loop/march_sample_expressive.svg
!loop/march_sample_balanced.png
!loop/march_sample_balanced.svg
!loop/march_sample_diamond.png
!loop/march_sample_diamond.svg

# Force-track the scorer's hard-negative fixtures — committed test assets that
# loop/tests/dscore_calib.sh scores against (the *.png rule above would ignore
# them). Regenerable via `python loop/tests/make_hard_negatives.py` (human-run).
!loop/tests/fixtures/hard_neg/*.png
!loop/tests/fixtures/borderline/*.png
